# Example environment file - copy to .env and fill in your values

# Required: Get this from @BotFather on Telegram
TELEGRAM_APPLE_NOTES_BOT=your_bot_token_here

# Optional: Name of the Apple Note to append to (default: "Telegram Bot")
APPLE_NOTE_NAME=Telegram Bot

# Optional: Parakeet model (default: mlx-community/parakeet-tdt-0.6b-v3)
# Models available:
# - mlx-community/parakeet-tdt-0.6b-v3 (English + multilingual, default)
# - mlx-community/parakeet-tdt-0.6b-v2 (English only)
# - mlx-community/parakeet-ctc-0.6b-v2 (English only)
PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v3
